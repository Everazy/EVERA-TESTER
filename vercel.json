{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/payment-selesai", "dest": "/public/payment-selesai.html" },
    { "src": "/admin/stok", "dest": "/public/admin-stok.html" },
    { "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|svg|ico|webp))", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
