# ─── Admin ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@everastore.biz.id
ADMIN_PASSWORD=gantiPasswordIni

# Generate token: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=GANTI_DENGAN_STRING_ACAK_PANJANG_32_KARAKTER
