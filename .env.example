# ─── Sakurupiah ───────────────────────────────────────────────
SAKURUPIAH_API_ID=ISI_API_ID_KAMU
SAKURUPIAH_API_KEY=ISI_API_KEY_KAMU
SAKURUPIAH_MERCHANT_CODE=SANBOX
SAKURUPIAH_BASE_URL=https://sakurupiah.id/api-sanbox/
SAKURUPIAH_CALLBACK_URL=https://everastore.biz.id/api/payments/callback
SAKURUPIAH_RETURN_URL=https://everastore.biz.id/payment-selesai
SAKURUPIAH_EXPIRED_HOURS=24
SAKURUPIAH_MERCHANT_FEE=1

# ─── Admin ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@everastore.biz.id
ADMIN_PASSWORD=gantiPasswordIni
# ADMIN_PASSWORD_SHA256=hash_sha256_opsional

# Token untuk API admin (generate string acak panjang, minimal 32 karakter)
# Contoh: buka terminal → node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=GANTI_DENGAN_TOKEN_ACAK_PANJANG_MINIMAL_32_KARAKTER
